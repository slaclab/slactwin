{
    "apiRoute": {
        "slactwinSimFromRunSummary": "/slactwin-sim-from-run-summary",
        "slactwinListMachines": "/slactwin-list-machines"
    },
    "appDefaults": {
        "route": "search"
    },
    "appInfo": {
        "slactwin": {
            "longName": "SLAC Digital Twin Database",
            "shortName": "SLAC TWIN"
        }
    },
    "appModes": {
        "default": {
            "localRoute": "visualization"
        }
    },
    "dynamicFiles": {
        "sirepoLibs": {
            "js": [
                "slactwin.js",
                "sirepo-lattice.js"
            ],
            "css": [
                "lattice.css",
                "slactwin.css",
                "sirepo-dark.css"
            ]
        }
    },
    "enum": {
        "PlotType": [
            ["heatmap", "Heatmap"],
            ["3d", "Heatmap with Histograms"]
        ]
    },
    "frameIdFields": {
        "animation": [
            "runSummaryId",
            "plotName",
            "x",
            "y",
            "histogramBins",
            "reportIndex"
        ],
        "summaryAnimation": ["runSummaryId"],
        "statAnimation": ["runSummaryId", "x", "y1", "y2", "y3", "y4", "y5"],
        "sigmaAnimation": ["runSummaryId", "comparisonRunSummaryId"],
        "twissAnimation": ["runSummaryId", "comparisonRunSummaryId"],
        "bunchAnimation1": ["runSummaryId", "comparisonRunSummaryId", "histogramBins", "x", "y"],
        "bunchAnimation2": ["runSummaryId", "comparisonRunSummaryId", "histogramBins", "x", "y"],
        "bunchAnimation3": ["runSummaryId", "comparisonRunSummaryId", "histogramBins", "x", "y"]
    },
    "localRoutes": {
        "search": {
            "route": "/search",
            "config": {
                "controller": "InitController",
                "template": "<div data-loading-indicator='\"Initializing Application...\"'></div>"
            }
        },
        "search-results": {
            "route": "/search-results/:simulationId",
            "config": {
                "controller": "SearchController as search",
                "templateUrl": "/static/html/slactwin-search.html"
            }
        },
        "beam": {
            "route": "/beam/:simulationId",
            "config": {
                "controller": "BeamController as beam",
                "templateUrl": "/static/html/slactwin-beam.html",
                "reloadOnSearch": false
            }
        },
        "comparison": {
            "route": "/comparison/:simulationId",
            "config": {
                "controller": "ComparisonController as comparison",
                "templateUrl": "/static/html/slactwin-comparison.html",
                "reloadOnSearch": false
            }
        },
        "lattice": {
            "route": "/lattice/:simulationId",
            "config": {
                "controller": "LatticeController as lattice",
                "templateUrl": "/static/html/slactwin-lattice.html",
                "reloadOnSearch": false
            }
        },
        "visualization": {
            "route": "/visualization/:simulationId",
            "config": {
                "controller": "VizController as viz",
                "templateUrl": "/static/html/slactwin-viz.html",
                "reloadOnSearch": false
            }
        }
    },
    "model": {
        "beamline": {
            "name": ["Name", "ValidatedString"]
        },
        "bunchAnimation": {
            "x": ["Horizontal Value to Plot", "ValueList", "x"],
            "y": ["Vertical Value to Plot", "ValueList", "px"],
            "plotType": ["Plot Type", "PlotType", "3d"],
            "histogramBins": ["Histogram Bins", "Integer", 50],
            "colorMap": ["Color Map", "ColorMap", "viridis"],
            "selectedFrame": ["", "FrameSlider", 0],
            "notes": ["Notes", "Text", ""]
        },
        "bunchAnimation1": {
            "runSummaryId": ["", "String", "0"],
            "comparisonRunSummaryId": ["", "String", "0"],
            "x": ["Horizontal Value to Plot", "ValueList", "x"],
            "y": ["Vertical Value to Plot", "ValueList", "px"],
            "plotType": ["Plot Type", "PlotType", "3d"],
            "histogramBins": ["Histogram Bins", "Integer", 50],
            "colorMap": ["Color Map", "ColorMap", "viridis"],
            "notes": ["Notes", "Text", ""]
        },
        "bunchAnimation2": {
            "runSummaryId": ["", "String", "0"],
            "comparisonRunSummaryId": ["", "String", "0"],
            "x": ["Horizontal Value to Plot", "ValueList", "x"],
            "y": ["Vertical Value to Plot", "ValueList", "px"],
            "plotType": ["Plot Type", "PlotType", "3d"],
            "histogramBins": ["Histogram Bins", "Integer", 50],
            "colorMap": ["Color Map", "ColorMap", "viridis"],
            "notes": ["Notes", "Text", ""]
        },
        "bunchAnimation3": {
            "runSummaryId": ["", "String", "0"],
            "comparisonRunSummaryId": ["", "String", "0"],
            "x": ["Horizontal Value to Plot", "ValueList", "x"],
            "y": ["Vertical Value to Plot", "ValueList", "px"],
            "plotType": ["Plot Type", "PlotType", "3d"],
            "histogramBins": ["Histogram Bins", "Integer", 50],
            "colorMap": ["Color Map", "ColorMap", "viridis"],
            "notes": ["Notes", "Text", ""]
        },
        "elementAnimation": {
            "runSummaryId": ["", "String", "0"],
            "plotName": ["", "String"],
            "x": ["X Value", "ValueList", ""],
            "y": ["Y Value", "ValueList", ""],
            "plotType": ["Plot Type", "PlotType", "3d"],
            "histogramBins": ["Histogram Bins", "Integer", 50],
            "colorMap": ["Color Map", "ColorMap", "viridis"],
            "aspectRatio": ["Aspect Ratio", "AspectRatio", "1"],
            "notes": ["Notes", "Text", ""],
            "reportIndex": ["", "Integer"]
        },
        "searchSettings": {
            "machine_name": ["Accelerator", "ValueList"],
            "twin_name": ["Model", "ValueList"],
            "searchStartTime":["Start", "DateTimePicker", null],
            "searchStopTime":["Stop", "DateTimePicker", null],
            "presetTimePicker": ["", "PresetTimePicker", ""],
            "pageSize": ["Page Size", "Integer", 15],
            "searchTerms": ["", "SearchTerms", []],
            "columns": ["", "Array", []],
            "isLive": ["View Live", "Boolean", "0"]
        },
        "searchTerm": {
            "column": ["Column", "ColumnList", ""],
            "minValue": ["Minimum Value", "OptionalFloat", ""],
            "maxValue": ["Maximum Value", "OptionalFloat", ""]
        },
        "statAnimation": {
            "runSummaryId": ["", "String", "0"],
            "x": ["Horizontal Value to Plot", "ValueList", ""],
            "y1": ["Vertical Value to Plot", "ValueList", ""],
            "y2": ["Vertical Value to Plot", "ValueList", ""],
            "y3": ["Vertical Value to Plot", "ValueList", ""],
            "y4": ["Vertical Value to Plot", "ValueList", ""],
            "y5": ["Vertical Value to Plot", "ValueList", ""],
            "y1Position": ["Vertical Postion", "AxisPosition", "left"],
            "y2Position": ["Vertical Position", "AxisPosition", "left"],
            "y3Position": ["Vertical Position", "AxisPosition", "right"],
            "y4Position": ["Vertical Position", "AxisPosition", "right"],
            "y5Position": ["Vertical Position", "AxisPosition", "right"],
            "leftLimit": ["Left Axis Limit", "Float", 0],
            "rightLimit": ["Right Axis Limit", "Float", 0],
            "includeLattice": ["Show Lattice Overlay", "Boolean", "1"],
            "aspectRatio": ["Aspect Ratio", "AspectRatio", "0.5"],
            "notes": ["Notes", "Text", ""]
        },
        "sigmaAnimation": {
            "runSummaryId": ["", "String", "0"],
            "comparisonRunSummaryId": ["", "String", "0"],
            "aspectRatio": ["Aspect Ratio", "AspectRatio", "0.5"],
            "includeLattice": ["Show Lattice Overlay", "Boolean", "1"],
            "notes": ["Notes", "Text", ""]
        },
        "summaryAnimation": {
            "runSummaryId": ["", "String", "0"]
        },
        "simulation": {
            "elementPosition": ["Element Positioning", "ElementPosition", "absolute"]
        },
        "twissAnimation": {
            "runSummaryId": ["", "String", "0"],
            "comparisonRunSummaryId": ["", "String", "0"],
            "aspectRatio": ["Aspect Ratio", "AspectRatio", "0.5"],
            "includeLattice": ["Show Lattice Overlay", "Boolean", "1"],
            "notes": ["Notes", "Text", ""]
        }
    },
    "strings": {
        "searchSettings": {
            "save": "Search"
        }
    },
    "view": {
        "beamline": {
            "title": "Beamline",
            "advanced": []
        },
        "bunchAnimation": {
            "hasDataFile": false,
            "canFullScreen": false,
            "title": "Phase Space",
            "advanced": [
                "plotType",
                [
                    ["Horizontal", [
                        "x"
                    ]],
                    ["Vertical", [
                        "y"
                    ]]
                ],
