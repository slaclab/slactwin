                    ]]
                ],
                "histogramBins",
                "aspectRatio",
                "colorMap",
                "notes"
            ]
        },
        "searchSettings": {
            "title": "Search Runs",
            "basic": [
                "machine_name",
                "twin_name",
                "searchStartTime",
                "searchStopTime",
                "presetTimePicker",
                "searchTerms"
            ],
            "advanced": []
        },
        "summaryAnimation": {
            "title": "Summary",
            "advanced": []
        },
        "statAnimation": {
            "title": "Beam Variables",
            "hasDataFile": false,
            "advanced": [
                ["Main", [
